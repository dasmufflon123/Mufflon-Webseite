name: Opfanze Datenbank aktualisieren

on:
  push:
    paths:
      - 'assets/Opfanze_assets/Extrablatt_2025/**'
      - 'assets/Opfanze_assets/Extrablatt_2026/**'
  workflow_dispatch:

jobs:
  update:
    runs-on: ubuntu-latest

    steps:
      - name: Repository auschecken
        uses: actions/checkout@v4

      - name: Python einrichten
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Skript ausführen
        run: python scripts/generate-opfanze-data.py

      - name: Änderungen committen
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add js/Opfanze-data.js
          git diff --staged --quiet || git commit -m "Opfanze-Datenbank automatisch aktualisiert [skip ci]"
          git push
